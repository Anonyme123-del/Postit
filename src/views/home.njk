{% include "partials/header.njk" %}

<main class="page">
  <aside class="sidebar">
    <section class="panel hero-panel">
      <p class="eyebrow">Tableau actif</p>
      <h1>{{ board.title }}</h1>
      <p class="board-meta">Slug : <strong>{{ board.slug }}</strong></p>
      <p class="board-tip">Double-clic (ou double tap) sur l’espace de travail pour créer un post-it.</p>
    </section>

    <form
      class="panel"
      action="/"
      method="get"
      onsubmit="event.preventDefault(); const slug = this.slug.value.trim().toLowerCase(); window.location.href = slug ? '/' + slug : '/';"
    >
      <h2>Changer de tableau</h2>
      <label for="slug">Nom du tableau</label>
      <input id="slug" name="slug" type="text" placeholder="ex : reseau" />
      <button type="submit">Ouvrir</button>
    </form>

    {% if not currentUser %}
      <form class="panel" action="/login" method="post">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <h2>Connexion</h2>

        <input type="hidden" name="boardSlug" value="{{ board.slug }}" />

        <label for="username">Utilisateur</label>
        <input id="username" name="username" type="text" required />

        <label for="password">Mot de passe</label>
        <input id="password" name="password" type="password" required />

        <button type="submit">Se connecter</button>
      </form>
    {% else %}
      <section class="panel">
        <h2>Session</h2>
        <p class="session-user">Connecté en tant que <strong>{{ currentUser.username }}</strong></p>

        <ul class="permission-list nice-list">
          <li>Création : <strong>{{ 'oui' if currentUser.permissions.canCreate else 'non' }}</strong></li>
          <li>Modification : <strong>{{ 'oui' if currentUser.permissions.canUpdate else 'non' }}</strong></li>
          <li>Suppression : <strong>{{ 'oui' if currentUser.permissions.canDelete else 'non' }}</strong></li>
          <li>Admin : <strong>{{ 'oui' if currentUser.permissions.isAdmin else 'non' }}</strong></li>
        </ul>

        <form action="/logout" method="post">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <input type="hidden" name="boardSlug" value="{{ board.slug }}" />
          <button type="submit" class="secondary-btn">Se déconnecter</button>
        </form>
      </section>
    {% endif %}

    {% if not currentUser %}
      <section class="panel muted-panel">
        <h2>Mode invité</h2>
        <p>Quand tu n’es pas connecté, les droits appliqués sont ceux du compte <strong>guest</strong>.</p>

        <ul class="permission-list nice-list">
          <li>Création : <strong>{{ 'oui' if permissions.canCreate else 'non' }}</strong></li>
          <li>Modification : <strong>{{ 'oui' if permissions.canUpdate else 'non' }}</strong></li>
          <li>Suppression : <strong>{{ 'oui' if permissions.canDelete else 'non' }}</strong></li>
        </ul>
      </section>
    {% endif %}
  </aside>

  <section class="workspace">
    <div class="workspace-header">
      <div>
        <p class="eyebrow">Secure workspace</p>
        <h2>Mur de post-it</h2>
      </div>
    </div>

    <section
      class="board"
      data-board-slug="{{ board.slug }}"
      data-current-user-id="{% if currentUser %}{{ currentUser.id }}{% endif %}"
      data-can-create="{{ '1' if permissions.canCreate else '0' }}"
      data-can-update="{{ '1' if permissions.canUpdate else '0' }}"
      data-can-delete="{{ '1' if permissions.canDelete else '0' }}"
      data-is-admin="{{ '1' if permissions.isAdmin else '0' }}"
      data-csrf-token="{{ csrfToken }}"
    >
      <div class="board-empty">
        <div class="empty-card">
          <h3>Aucun post-it pour le moment</h3>
          <p>Crée le premier avec un double-clic dans l’espace de travail.</p>
        </div>
      </div>
    </section>
  </section>
</main>

<dialog id="postit-modal" class="modal">
  <form method="dialog" class="modal-card" id="postit-form">
    <h2 id="postit-modal-title">Nouveau post-it</h2>
    <textarea id="postit-content" name="content" maxlength="300" required placeholder="Écris ici..."></textarea>
    <menu class="modal-actions">
      <button type="button" id="postit-cancel" class="secondary">Annuler</button>
      <button type="submit" id="postit-submit">Valider</button>
    </menu>
  </form>
</dialog>

{% include "partials/footer.njk" %}