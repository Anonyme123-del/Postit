<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
</head>
<body>
  <h1>Accueil utilisateur</h1>

  <p>Bienvenue <strong>{{ currentUser.username }}</strong></p>

  <h2>Vos permissions</h2>
  <ul>
    <li>Création : {% if currentUser.permissions.canCreate %}Oui{% else %}Non{% endif %}</li>
    <li>Modification : {% if currentUser.permissions.canUpdate %}Oui{% else %}Non{% endif %}</li>
    <li>Effacement : {% if currentUser.permissions.canDelete %}Oui{% else %}Non{% endif %}</li>
    <li>Administration : {% if currentUser.permissions.isAdmin %}Oui{% else %}Non{% endif %}</li>
  </ul>

  <form method="POST" action="/logout">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <button type="submit">Se déconnecter</button>
  </form>
</body>
</html>